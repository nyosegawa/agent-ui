{
  "name": "@nyosegawa/agent-ui-server",
  "version": "0.0.0",
  "description": "Node local bridge helpers for Agent UI.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts test"
  },
  "dependencies": {
    "@nyosegawa/agent-ui-codex": "workspace:*",
    "@nyosegawa/agent-ui-core": "workspace:*",
    "execa": "9.6.1",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/ws": "8.18.1"
  }
}
