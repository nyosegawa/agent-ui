{
  "name": "@nyosegawa/agent-ui-server",
  "version": "0.4.1",
  "description": "Node local bridge helpers for Agent UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyosegawa/agent-ui.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/nyosegawa/agent-ui/issues"
  },
  "homepage": "https://github.com/nyosegawa/agent-ui#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts test"
  },
  "dependencies": {
    "@nyosegawa/agent-ui-codex": "workspace:^0.4.1",
    "@nyosegawa/agent-ui-core": "workspace:^0.4.1",
    "execa": "9.6.1",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@types/ws": "8.18.1"
  }
}
