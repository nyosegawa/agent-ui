{
  "name": "@nyosegawa/agent-ui-core",
  "version": "1.1.0",
  "description": "Protocol-neutral state and transport primitives for Agent UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyosegawa/agent-ui.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nyosegawa/agent-ui/issues"
  },
  "homepage": "https://github.com/nyosegawa/agent-ui#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts test"
  }
}
