{
  "name": "@nyosegawa/agent-ui-react",
  "version": "0.1.1",
  "description": "React hooks and components for Agent UI.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyosegawa/agent-ui.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/nyosegawa/agent-ui/issues"
  },
  "homepage": "https://github.com/nyosegawa/agent-ui#readme",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./dist/styles/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": {
      "types": "./dist/styles.css.d.ts",
      "default": "./dist/styles.css"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css && cp src/styles.css.d.ts dist/styles.css.d.ts && rm -rf dist/styles && cp -R src/styles dist/styles",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts --environment jsdom test"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@nyosegawa/agent-ui-codex": "workspace:^0.1.1",
    "@nyosegawa/agent-ui-core": "workspace:^0.1.1"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "devDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
