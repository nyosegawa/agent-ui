{
  "name": "@nyosegawa/agent-ui-react",
  "version": "0.0.0",
  "description": "React hooks and components for Agent UI.",
  "license": "MIT",
  "type": "module",
  "sideEffects": ["./dist/style.css"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./style.css": {
      "types": "./dist/style.css.d.ts",
      "default": "./dist/style.css"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && cp src/style.css dist/style.css && cp src/style.css.d.ts dist/style.css.d.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts --environment jsdom packages/react/test"
  },
  "dependencies": {
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@nyosegawa/agent-ui-core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "devDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
