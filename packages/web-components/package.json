{
  "name": "@nyosegawa/agent-ui-web-components",
  "version": "0.0.0",
  "description": "Web Components wrapper for Agent UI React components.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=20"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts --environment jsdom test"
  },
  "dependencies": {
    "@nyosegawa/agent-ui-core": "workspace:*",
    "@nyosegawa/agent-ui-react": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "devDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
