{
  "name": "@nyosegawa/agent-ui-web-components",
  "version": "1.0.0",
  "description": "Web Components wrapper for Agent UI React components.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nyosegawa/agent-ui.git",
    "directory": "packages/web-components"
  },
  "bugs": {
    "url": "https://github.com/nyosegawa/agent-ui/issues"
  },
  "homepage": "https://github.com/nyosegawa/agent-ui#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts --environment jsdom test"
  },
  "dependencies": {
    "@nyosegawa/agent-ui-core": "workspace:^1.0.0",
    "@nyosegawa/agent-ui-react": "workspace:^1.0.0"
  },
  "peerDependencies": {
    "react": ">=18.3.0 || >=19.0.0",
    "react-dom": ">=18.3.0 || >=19.0.0"
  },
  "devDependencies": {
    "react": "19.2.6",
    "react-dom": "19.2.6"
  }
}
