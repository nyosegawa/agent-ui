{
  "name": "agent-ui",
  "version": "0.0.0",
  "private": true,
  "description": "Embeddable UI for Codex-powered coding agents",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "bun run --workspaces --if-present build",
    "check:exports": "bun run publint && bun run attw",
    "validate:packages": "bun run build && bun run publint && bun run attw",
    "format": "prettier --write .",
    "typecheck": "bun run --workspaces --if-present typecheck",
    "lint": "eslint .",
    "check:dead-code": "knip --include files,exports,dependencies --reporter compact",
    "test": "vitest run",
    "test:protocol": "bun test packages/codex/test",
    "test:fixtures": "bun test packages/core/test",
    "test:node-compat": "node scripts/node-compat-smoke.mjs",
    "test:package-resolution": "node scripts/package-resolution-smoke.mjs",
    "test:e2e:real-codex": "node scripts/real-codex-smoke.mjs",
    "test:e2e:real-codex:approval": "node scripts/real-codex-smoke.mjs --approval",
    "test:e2e:playwright": "env -u NO_COLOR -u FORCE_COLOR playwright test",
    "test:e2e:real-local-web-layout": "node scripts/real-local-web-layout-audit.mjs",
    "publint": "for p in packages/*; do publint \"$p\" || exit 1; done",
    "attw": "for p in packages/*; do attw --pack \"$p\" --ignore-rules cjs-resolves-to-esm no-resolution || exit 1; done"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@changesets/cli": "2.31.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.13",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react-hooks": "7.1.1",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "knip": "^6.14.1",
    "prettier": "3.8.3",
    "publint": "0.3.20",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  }
}
